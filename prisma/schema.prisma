generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  moods             MoodEntry[]
  gratitudeEntries  GratitudeEntry[]
  breathingSessions BreathingSession[]
  chatMessages      ChatMessage[]
}

model MoodEntry {
  id        String   @id @default(cuid())
  mood      String
  emoji     String
  value     Int
  color     String
  note      String?
  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model GratitudeEntry {
  id        String   @id @default(cuid())
  text      String
  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model BreathingSession {
  id              String   @id @default(cuid())
  durationSeconds Int
  completedCycles Int
  createdAt       DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ChatMessage {
  id        String   @id @default(cuid())
  role      String
  text      String
  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}
